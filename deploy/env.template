# era environment — /etc/era/env on the VPS, mode 600 era:era.
# All values except comments are required.

# --- Telegram ---
PI_TELEGRAM_BOT_TOKEN=
PI_TELEGRAM_ALLOWED_USER_ID=

# --- GitHub App (not PAT) ---
PI_GITHUB_APP_ID=
PI_GITHUB_APP_INSTALLATION_ID=
PI_GITHUB_SANDBOX_REPO=

# --- LLM ---
PI_OPENROUTER_API_KEY=
PI_MODEL=moonshotai/kimi-k2.6

# --- Tavily search ---
PI_TAVILY_API_KEY=

# --- Runtime ---
PI_DB_PATH=/opt/era/pi-agent.db
PI_DIGEST_TIME_UTC=17:30
